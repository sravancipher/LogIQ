APP_NAME=Project Monitor API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
QUEUE_POLL_INTERVAL_SECONDS=5
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=
